# DelovodAI — конфигурация окружения

# Адрес Ollama-сервера (хост:порт)
# По умолчанию: ollama:11434 (для сети SelfHostedAI)
OLLAMA_HOST=ollama:11434

# Токен Telegram-бота (опционально)
# Если не задан, работа только через Web UI
TELEGRAM_BOT_TOKEN=

# Пароль для Web UI (опционально)
# Если не задан, Web UI без аутентификации (c предупреждением)
WEBUI_PASSWORD=

# Порт Web UI
# По умолчанию: 3000
WEBUI_PORT=3000

# Порт CalDAV-сервера (Radicale)
# По умолчанию: 5232
CALDAV_PORT=5232

# Модель Ollama по умолчанию
# По умолчанию: gpt-oss:20b
DEFAULT_MODEL=gpt-oss:20b

# Часовой пояс
TZ=Europe/Moscow

# Разрешённые пользователи Telegram (JSON-массив числовых ID)
# Если не задан или пуст — используется ручной pairing
# TELEGRAM_ALLOWED_USERS=[123456789,987654321]

# IP-адрес Telegram Bot API (для обхода блокировок DNS)
# По умолчанию: 149.154.167.220
# TELEGRAM_API_IP=149.154.167.220
